InputFilepaths:
  simPath: "/mnt/aridata1/users/ariadurr/WORK/Simulations/Boxes/{simName}"
  skiFilepath: "/mnt/aridata1/users/ariadurr/WORK/Processing/colibre-skirt/template_v{skifileversion}.ski"

  catalogueFile: "{simPath}/SOAP/halo_properties_{snap_nr:04d}.hdf5"

  # If the snapshots are distributed
  virtualSnapshotFile: "{simPath}/SOAP/colibre_with_SOAP_membership_{snap_nr:04d}.hdf5"

  # If not distributed you need to provide the membership and snapshot information separately
  snapshotFile: "{simPath}/snapshots/colibre_{snap_nr:04d}.hdf5"
  membershipFile: "{simPath}/SOAP/membership_{snap_nr:04d}.hdf5"

OutputFilepaths:
  sampleFolder: "{simPath}/SKIRT/samples/" # Folder where the galaxy sample .txt files are stored.
  storeParticlesPath: "{simPath}/SKIRT/samples/" # Folder where the .txt particle files are stored
  SKIRTinputFilePath: "{simPath}/SKIRT/InputFiles/" # Path where the SKIRT input files will be stored
  skiFilepath: "{simPath}/SKIRT/skiFiles/"
  haloPropertiesFile: "{simPath}/SKIRT/SKIRT_halo_properties_{snap_nr:04d}.hdf5" # Path where SOAP-like halo datasets will be stored from integrated halo SEDs

SelectionCriteria:
  minStellarMass: 1.504e7 # Lower stellar mass limit for halo selection in Msun
  maxStellarMass: 2.0e7 # Upper stellar mass limit for halo selection in Msun